{
  "name": "eclia",
  "private": true,
  "scripts": {
    "build:shared": "pnpm -C packages/config build && pnpm -C packages/gateway-client build && pnpm -C packages/utils build",
    "dev:web": "pnpm -C apps/web-console dev",
    "dev:api": "pnpm -C apps/gateway dev",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:discord": "pnpm -C apps/adapter/discord dev",
    "dev:telegram": "pnpm -C apps/adapter/telegram dev",
    "build:web": "pnpm -C apps/web-console build",
    "dev:gateway": "pnpm -C apps/gateway dev",
    "typecheck": "pnpm build:shared && pnpm -r --if-present run typecheck",
    "typecheck:watch": "pnpm build:shared && pnpm -r --if-present --parallel run typecheck:watch",
    "dev:memory": "pnpm -C apps/memory dev",
    "dev:symphony": "pnpm -C apps/symphony dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "pnpm": {
    "packageExtensions": {
      "request-promise-core@1.1.3": {
        "peerDependenciesMeta": {
          "request": {
            "optional": true
          }
        }
      }
    }
  }
}
