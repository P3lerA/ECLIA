{
  "name": "memory",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/setup-sidecar.mjs",
    "dev": "pnpm -C ../../packages/config build && pnpm -C ../../packages/gateway-client build && tsx server/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:watch": "tsc -p tsconfig.json --noEmit -w --preserveWatchOutput"
  },
  "dependencies": {
    "@eclia/config": "workspace:*",
    "@eclia/gateway-client": "workspace:*",
    "@eclia/utils": "workspace:*",
    "@libsql/client": "^0.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.31",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
